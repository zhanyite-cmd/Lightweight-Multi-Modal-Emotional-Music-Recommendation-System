        <mxCell id="title" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#6b8e6b;strokeWidth=2;fontSize=18;fontWeight=bold;" value="Lightweight Multi-Modal Emotional Music Recommendation System&amp;nbsp;" vertex="1">
          <mxGeometry height="60" width="1000" x="300" y="30" as="geometry" />
        </mxCell>
        <mxCell id="layer1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f8ff;strokeColor=#4682b4;strokeWidth=1;fontSize=14;fontWeight=bold;" value="Research Background and Problem Statement" vertex="1">
          <mxGeometry height="50" width="1000" x="300" y="120" as="geometry" />
        </mxCell>
        <mxCell id="layer1-content" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;strokeWidth=1;fontSize=12;" value="Traditional music recommendation relies on behavior and content features, cannot capture real-time emotion&lt;br&gt;Single-modal emotion recognition lacks robustness in complex scenes&lt;br&gt;No lightweight, edge-deployable multi-modal emotional music recommendation scheme" vertex="1">
          <mxGeometry height="70" width="1000" x="300" y="180" as="geometry" />
        </mxCell>
        <mxCell id="layer2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f8ff;strokeColor=#4682b4;strokeWidth=1;fontSize=14;fontWeight=bold;" value="Literature Review and Research Gaps" vertex="1">
          <mxGeometry height="50" width="1000" x="300" y="270" as="geometry" />
        </mxCell>
        <mxCell id="layer2-content" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;strokeWidth=1;fontSize=12;" value="Lightweight text emotion: Tiny-BERT, DistilRoBERTa&lt;br&gt;Facial emotion: YOLO detection + lightweight CNN&lt;br&gt;Music-emotion mapping: audio features + user comment emotion&lt;br&gt;Gaps: insufficient dual-modal fusion, no UGC integration, poor edge deployment" vertex="1">
          <mxGeometry height="90" width="1000" x="300" y="330" as="geometry" />
        </mxCell>
        <mxCell id="layer3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f8ff;strokeColor=#4682b4;strokeWidth=1;fontSize=14;fontWeight=bold;" value="Overall Research Framework" vertex="1">
