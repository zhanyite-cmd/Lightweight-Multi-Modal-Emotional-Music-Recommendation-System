          <mxGeometry height="80" width="230" x="300" y="800" as="geometry" />
        </mxCell>
        <mxCell id="mod2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1;fontSize=13;fontWeight=bold;" value="Text Emotion Module" vertex="1">
