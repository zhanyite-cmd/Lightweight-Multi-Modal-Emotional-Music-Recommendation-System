        </mxCell>
        <mxCell id="layer3-content" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;strokeWidth=1;fontSize=12;" value="Facial Emotion Recognition + Text Emotion Recognition -&gt; Weighted Fusion -&gt; Emotion-Music Matching -&gt; Lightweight Edge Deployment" vertex="1">
          <mxGeometry height="50" width="1000" x="300" y="500" as="geometry" />
        </mxCell>
        <mxCell id="layer4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f8ff;strokeColor=#4682b4;strokeWidth=1;fontSize=14;fontWeight=bold;" value="Core Module Implementation" vertex="1">
