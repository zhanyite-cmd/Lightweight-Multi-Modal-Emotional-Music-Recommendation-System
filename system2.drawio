        <mxCell id="mod3-content" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;strokeWidth=1;fontSize=11;" value="Weighted Decision Fusion&lt;br&gt;wf=0.6, wt=0.4&lt;br&gt;Efinal=argmax(wf*Sf+wt*St)&lt;br&gt;Output Final Emotion" vertex="1">
          <mxGeometry height="80" width="230" x="800" y="800" as="geometry" />
